# ============================================================
# Energy Intelligence System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── REQUIRED ──────────────────────────────────────────────────
# OpenRouter API key for LLM (AI insights, agents, chat)
# Get yours at: https://openrouter.ai/keys
# Without this key, system runs in rule-based mode (no AI features)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── DATA SOURCE ───────────────────────────────────────────────
# Which data to use: "sample" (synthetic demo data) or "real" (your uploaded data)
EIS_DATA_SOURCE=sample

# ── AGENTIC AI ────────────────────────────────────────────────
# Enable/disable the multi-agent AI system (Commander, Specialists, Briefing)
EIS_AGENT_ENABLED=true

# ── OUTLOOK EMAIL ALERTS (Optional) ──────────────────────────
# SMTP settings for sending email alerts via Outlook
# Leave blank to disable email features
EIS_SMTP_SERVER=smtp.office365.com
EIS_SMTP_PORT=587
EIS_SMTP_USER=your-email@company.com
EIS_SMTP_PASSWORD=your-app-password
